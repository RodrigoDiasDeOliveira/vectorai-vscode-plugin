{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.json",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "node": true,
    "es2022": true
  },
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "src/_mocks_/" ,
    "src/_tests_/"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": "warn" ,
    "@typescript-eslint/no-explicit-any": "off"
  }
}